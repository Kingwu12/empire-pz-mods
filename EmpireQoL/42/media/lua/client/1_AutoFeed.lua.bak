-- Empire QoL - Auto Eat & Drink
-- Watches hunger/thirst moodles, auto-eats/drinks from inventory or nearby containers

local EmpireAutoFeed = {}

-- How often to check (every N game ticks, ~1 tick per second)
local CHECK_INTERVAL = 60
local tickCount = 0

-- Moodle levels: 1=hungry, 2=very hungry, 3=starving / 1=thirsty, 2=very thirsty, 3=parched
local HUNGER_THRESHOLD = 2   -- trigger on "Very Hungry"
local THIRST_THRESHOLD = 2   -- trigger on "Very Thirsty"

-- Item categories to consider as food/drink
local FOOD_CATEGORIES = { Food = true, Drink = true }

-- Never auto-eat these (raw meat, rotten food, etc)
local BLACKLIST = {
    ["RawMeat"] = true, ["RawBacon"] = true, ["RawRabbit"] = true,
    ["RawFish"] = true, ["BadFood"] = true,
}

local function isSafeFood(item)
    if BLACKLIST[item:getType()] then return false end
    if not instanceof(item, "Food") then return false end
    if item:isRotten() then return false end
    if item:getHungerChange() >= 0 then return false end -- must reduce hunger
    return true
end

local function isSafeDrink(item)
    if not instanceof(item, "Food") then return false end
    if item:getThirstChange() >= 0 then return false end
    return true
end

local function findFoodInInventory(player, wantDrink)
    local inv = player:getInventory()
    local items = inv:getItems()
    local best = nil
    local bestVal = 0

    for i = 0, items:size() - 1 do
        local item = items:get(i)
        if item then
            local cat = item:getCategory()
            if FOOD_CATEGORIES[cat] then
                if wantDrink then
                    local tc = (instanceof(item, "Food") and item:getThirstChange()) or 0
                    if tc < 0 and isSafeDrink(item) then
                        local val = math.abs(tc)
                        if val > bestVal then bestVal = val; best = item end
                    end
                else
                    local hc = (instanceof(item, "Food") and item:getHungerChange()) or 0
                    if hc < 0 and isSafeFood(item) then
                        local val = math.abs(hc)
                        if val > bestVal then bestVal = val; best = item end
                    end
                end
            end
        end
    end
    return best
end

local function findFoodNearby(player, wantDrink)
    -- Check nearby containers (fridge, shelves etc)
    local px = math.floor(player:getX())
    local py = math.floor(player:getY())
    local pz = math.floor(player:getZ())
    local radius = 6

    for x = px - radius, px + radius do
        for y = py - radius, py + radius do
            local sq = getCell():getGridSquare(x, y, pz)
            if sq then
                local objects = sq:getObjects()
                for i = 0, objects:size() - 1 do
                    local obj = objects:get(i)
                    if obj and obj:getContainer() then
                        local c = obj:getContainer()
                        if not c:isLocked() then
                            local citems = c:getItems()
                            for j = 0, citems:size() - 1 do
                                local item = citems:get(j)
                                if item then
                                    local cat = item:getCategory()
                                    if FOOD_CATEGORIES[cat] then
                                        if wantDrink then
                                            local tc = (instanceof(item, "Food") and item:getThirstChange()) or 0
                                            if tc < 0 and isSafeDrink(item) then
                                                -- Transfer to inventory first
                                                c:Remove(item)
                                                player:getInventory():AddItem(item)
                                                return item
                                            end
                                        else
                                            local hc = (instanceof(item, "Food") and item:getHungerChange()) or 0
                                            if hc < 0 and isSafeFood(item) then
                                                c:Remove(item)
                                                player:getInventory():AddItem(item)
                                                return item
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return nil
end

local function tryEat(player, item)
    if not item then return end
    ISTimedActionQueue.add(ISEatFoodAction:new(player, item, 1))
    HaloTextHelper.addText(player, "Auto-eating " .. item:getName(), HaloTextHelper.getColorGreen())
end

local function tryDrink(player, item)
    if not item then return end
    ISTimedActionQueue.add(ISEatFoodAction:new(player, item, 1))
    HaloTextHelper.addText(player, "Auto-drinking " .. item:getName(), HaloTextHelper.getColorBlue())
end

local function onTick()
    tickCount = tickCount + 1
    if tickCount < CHECK_INTERVAL then return end
    tickCount = 0

    local player = getSpecificPlayer(0)
    if not player or player:isDead() or player:isAsleep() then return end

    -- Don't auto-feed during combat (zombies chasing)
    if player:getStats():getNumChasingZombies() > 0 then return end

    local stats = player:getStats()

    -- Check hunger
    local hunger = stats:getHunger()  -- 0=full, 1=starving
    if hunger >= (HUNGER_THRESHOLD * 0.33) then
        local food = findFoodInInventory(player, false) or findFoodNearby(player, false)
        if food then tryEat(player, food) end
    end

    -- Check thirst
    local thirst = stats:getThirst()  -- 0=full, 1=parched
    if thirst >= (THIRST_THRESHOLD * 0.33) then
        local drink = findFoodInInventory(player, true) or findFoodNearby(player, true)
        if drink then tryDrink(player, drink) end
    end
end

Events.OnTick.Add(onTick)
print("[EmpireQoL] Auto Eat/Drink loaded.")
return EmpireAutoFeed
