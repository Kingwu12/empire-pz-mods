-- Empire QoL - Auto Medicate
-- Auto-bandages wounds, takes painkillers when hurt, disinfects when needed

local CHECK_INTERVAL = 120  -- check every 2 seconds
local tickCount = 0

local BANDAGE_TYPES = {
    "Bandage", "RippedSheetsBandage", "DirtiedBandage",
    "Bandage_Sterile", "AdhesiveBandage",
}

local DISINFECT_TYPES = {
    "Disinfectant", "Alcohol", "AlcoholWipes", "LiquidBleach",
}

local PAINKILLER_TYPES = {
    -- NEVER list Sleeping Tablets here: auto-dosing them for pain makes you drowsy and
    -- fights the sleep system. Real painkillers only.
    "Painkillers", "Ibuprofen",
}

local function findItemByTypes(inv, types)
    for _, t in ipairs(types) do
        local item = inv:FindAndReturn(t)
        if item then return item end
    end
    return nil
end

local function partNeedsBandage(part)
    return (part:bleeding() or part:scratched() or part:deepWounded()
            or part:bitten() or part:isBurnt())
        and not part:bandaged()
end

local function doMedicate()
    local player = getSpecificPlayer(0)
    if not player or player:isDead() or player:isAsleep() then return end
    if player:getStats():getNumChasingZombies() > 0 then return end

    local inv = player:getInventory()
    local bodyDamage = player:getBodyDamage()
    if not bodyDamage then return end

    local parts = bodyDamage:getBodyParts()

    -- Bandage the first untreated wound
    local bandage = findItemByTypes(inv, BANDAGE_TYPES)
    if bandage then
        for i = 0, parts:size() - 1 do
            local part = parts:get(i)
            if part and partNeedsBandage(part) then
                ISTimedActionQueue.add(ISApplyBandage:new(player, player, bandage, part, true))
                HaloTextHelper.addText(player, "Auto-bandaging wound", HaloTextHelper.getColorYellow())
                break
            end
        end
    end

    -- Painkillers if in significant pain
    if player:getStats():getPain() > 30 then
        local pills = findItemByTypes(inv, PAINKILLER_TYPES)
        if pills then
            ISTimedActionQueue.add(ISEatFoodAction:new(player, pills, 1))
            HaloTextHelper.addText(player, "Auto-taking painkillers", HaloTextHelper.getColorRed())
        end
    end
end

local function onTick()
    tickCount = tickCount + 1
    if tickCount < CHECK_INTERVAL then return end
    tickCount = 0
    pcall(doMedicate)
end

Events.OnTick.Add(onTick)
print("[EmpireQoL] Auto Medicate loaded.")
