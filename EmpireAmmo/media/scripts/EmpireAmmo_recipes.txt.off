module Base
{
	imports
	{
		Smelting
	}

	/* ===================================================================
	   EMPIRE AMMO - lean low-item-volume reload overrides.
	   Every round is pressed straight from the universal lead + brass
	   currency (Smelting.projectilelead / Smelting.projectilebrass) plus
	   1 powder + 1 primer. No per-caliber Lead##/Brass##/Hull## pellet,
	   casing or hull ITEMS in the path -> a fraction of the item churn.
	   One craft yields a stack of 10. Change the "=10" to tune yield.
	   These override the same-named recipes in ammo_smelting + GunFighter,
	   so this mod MUST load AFTER both of them.
	   =================================================================== */

	/* ---------- PISTOL / SMG ---------- */
	recipe Make 5.7x28mm Ammunition
	{
		Smelting.projectilelead = 1,
		Smelting.projectilebrass = 1,
		GunPowder = 1,
		PrimerSM = 1,
		keep Lyman_TMag/Lee_LoadMaster,
		Sound : Reloading_Press,
		Result : Base.Bullets57=10,
		Time : 30.0,
		CanBeDoneFromFloor : TRUE,
		NeedToBeLearn : true,
	}
	recipe Make 380-ACP Ammunition
	{
		Smelting.projectilelead = 1,
